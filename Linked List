#include <iostream>
#include <string>
using namespace std;

struct Node {
    string name;
    Node* next;
};

int main() {
    Node* head;
    Node* one = NULL;
    Node* two = NULL;
    Node* three = NULL;
    Node* four = NULL;

    one = new Node();
    two = new Node();
    three = new Node();
    four = new Node();

    one->name = "Aimar";
    two->name = "Ahmad";
    three->name = "Anjana";
    four->name = "Jessy";

    one->next = two;
    two->next = three;
    three->next = four;
    four->next = NULL;

    head = one;
    while (head != NULL) {
        cout << head->name << " ";
        head = head->next;
    }

    return 0;
}
